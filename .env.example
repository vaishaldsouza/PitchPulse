# Server-side AI configuration. Never commit the real .env file.
# Omit AI_PROVIDER and all keys to use the safe local demo mode.
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=your-key-here
# For other providers, set AI_PROVIDER to openai, gemini, or openai_compatible
# and use OPENAI_API_KEY, GEMINI_API_KEY, or AI_API_KEY respectively.
# openai_compatible also requires AI_BASE_URL=https://provider.example
# HTTP is allowed only for http://localhost, http://127.0.0.1, or http://[::1].
PORT=5000
