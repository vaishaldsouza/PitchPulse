{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["backend/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/ops", "dest": "/dashboard.html" },
    { "src": "/(.+\\..+)", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
